
body {
    background-color: #f6f4f9d6;
}

header {
    text-align: center;
    margin-bottom: 30px;
}

    header h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

.filters {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 10px;
}

    .filters input,
    .filters select {
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 8px;
        font-size: 1rem;
    }

.gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 20px;
    margin-top: 30px;
}

.prompt-card {
    background-color: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    height: 305px;
    transition: transform 0.2s ease;
}

    .prompt-card:hover {
        transform: translateY(-5px);
    }

    .prompt-card h2 {
        font-size: 1.2rem;
        margin-bottom: 10px;
        color: #5a3e85;
        font-weight: lighter;
        text-align: end;
    }

    .prompt-card p {
        font-size: 0.95rem;
        color: #555;
        max-height: 50%;
        overflow: auto;
    }

#new-btn {
    margin-top: 10px;
    padding: 8px 12px;
    background-color: #5a3e85;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
}

    #new-btn:hover {
        background-color: #472f6c;
    }


.edit-btn {
    margin-top: 10px;
    padding: 8px 12px;
    background-color: #5a3e85;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
}

    .edit-btn:hover {
        background-color: #472f6c;
    }


