@model CardsViewModel
@{
    ViewData["Title"] = "Prompt Inspiration";
}
<header>
    <div><h2>🎨 Prompts Library</h2></div>
    <div class="filters">
        <div id="count" style="margin:auto;"></div>
        <input type="text" placeholder="Recherche prompts..." id="searchBar" />
        <select id="categoryFilter">
            <option value="all">Toutes catégories</option>
            @foreach (string item in Model.allCategories)
            {
                <option value="@item">@item</option>
            }
        </select>
        <select id="topicFilter">
            <option value="all">Tous les sujets</option>
            @foreach (string item in Model.allSubCategories)
            {
                <option value="@item">@item</option>
            }
        </select>
        <select id="framworkFilter">
            <option value="all">Tous les frameworks</option>
            @foreach (string item in Model.allframework)
            {
                <option value="@item">@item</option>
            }
        </select>
    </div>
    <div>
        <button id="new-btn">Créer</button>
    </div>

</header>

<main class="gallery" id="gallery" style="padding: 50px;">
    
   @foreach (CardViewModel item in Model.allCards)
    {
        <div class="prompt-card" data-category=@item.Categorie data-topic=@item.SubCategorie data-framework=@item.Framework>
            <h2>@item.Titre</h2>
            <div style="text-decoration: underline solid #b39ed2d6;margin-bottom: 8px;"><i>Preview : </i></div>
            <div class="frameworkCurrent" style="display:none;">@item.Framework</div>
            <p>@item.Content</p>
            <button class="edit-btn">Voir</button>
        </div>
        
    }
</main>

<style>

    body {
        background-color: #f6f4f9d6;
    }
    header {
        text-align: center;
        margin-bottom: 30px;
    }

        header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

    .filters {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

        .filters input,
        .filters select {
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-size: 1rem;
        }

    .gallery {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .prompt-card {
        background-color: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        height: 305px;
        transition: transform 0.2s ease;
    }

        .prompt-card:hover {
            transform: translateY(-5px);
        }

        .prompt-card h2 {
            font-size: 1.2rem;
            margin-bottom: 10px;
            color: #5a3e85;
            font-weight: lighter;
            text-align: end;
        }

        .prompt-card p {
            font-size: 0.95rem;
            color: #555;
            max-height: 50%;
            overflow: auto;
        }

    #new-btn {
        margin-top: 10px;
        padding: 8px 12px;
        background-color: #5a3e85;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

        #new-btn:hover {
            background-color: #472f6c;
        }


    .edit-btn {
        margin-top: 10px;
        padding: 8px 12px;
        background-color: #5a3e85;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

        .edit-btn:hover {
            background-color: #472f6c;
        }
</style>
<script src="~/js/catalogue.js"></script>
@section additionnalhead {
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" asp-append-version="true" />
}
