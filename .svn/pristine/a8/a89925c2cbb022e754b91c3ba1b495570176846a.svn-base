<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PromptLibrary_Web</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Main.css" asp-append-version="true" />

    @await RenderSectionAsync("additionnalhead", required: false)
</head>
<body>
    <header>
        <div class="logo">🌐 PromptLibrary - POC</div>
        <div class="user-info">Connecté : User Name - Ville</div>


        <nav class="nav-actions">
            <a class="admin-btn" asp-controller="Administration" asp-action="Index">
                Administration
            </a>

            <a class="prompt-btn" asp-controller="Catalogue" asp-action="Index">
                Prompts
            </a>
        </nav>


    </header>
    @RenderBody()
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
