
:root {
    --bg: #1e1e1e;
    --surface: #2a2a2a;
    --surface-2: #333333;
    --text: #e6e6e6;
    --text-muted: #b7b7b7;
    --border: #3a3a3a;
    --accent: #6a4caf;
    --accent-hover: #5a3e85;
    --accent-soft: #9d7bd8;
    --danger: #e74c3c;
    --danger-hover: #c0392b;
    --shadow-1: 0 4px 10px rgba(0,0,0,0.35);
    --shadow-2: 0 6px 14px rgba(0,0,0,0.45);
}

* {
    box-sizing: border-box;
    scrollbar-color: var(--surface-2) transparent;
}

html {
    color-scheme: dark;
}
header {
    text-align: center;
    margin-bottom: 30px;
    color: white !important;
}

body {
    background-color: var(--bg) !important;
    color: var(--text) !important;
    font-synthesis-weight: none;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

::selection {
    background: rgba(154, 123, 216, 0.35);
    color: #fff;
}

a {
    color: var(--accent-soft);
}

    a:hover {
        color: #d5c5ff;
    }

:where(a, button, [role="button"], input, select, textarea):focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 6px;
}

*::-webkit-scrollbar {
    width: 10px;
    height: 10px;
}

*::-webkit-scrollbar-track {
    background: transparent;
}

*::-webkit-scrollbar-thumb {
    background: var(--surface-2);
    border: 2px solid transparent;
    border-radius: 10px;
    background-clip: padding-box;
}

    *::-webkit-scrollbar-thumb:hover {
        background: #3c3c3c;
    }



.filters {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 10px;
}

    .filters input,
    .filters select {
        padding: 10px;
        background: var(--surface-2);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 1rem;
    }

        .filters input::placeholder {
            color: var(--text-muted);
        }

        .filters input:focus,
        .filters select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 .2rem rgba(140,108,196, .2);
            outline: none;
        }

.gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 20px;
    margin-top: 30px;
}

.prompt-card {
    background-color: var(--surface);
    color: var(--text);
    padding: 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-1);
    height: 305px;
    transition: transform 0.2s ease, box-shadow .2s ease, border-color .2s ease;
}

    .prompt-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-2);
        border-color: #4a3a67;
    }

    .prompt-card h2 {
        font-size: 1.2rem;
        margin-bottom: 10px;
        color: #5a3e85;
        font-weight: lighter;
        text-align: end;
    }

    .prompt-card p {
        font-size: 0.95rem;
        color: var(--text-muted);
        max-height: 50%;
        overflow: auto;
    }

#new-btn {
    margin-top: 10px;
    padding: 8px 12px;
    background-color: var(--accent);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease;
}

    #new-btn:hover {
        background-color: var(--accent-hover);
        transform: translateY(-1px);
    }

.edit-btn {
  display: inline-block;
  padding: 6px 14px;
  background-color: #6a4caf;
  color: #fff !important;
  border-radius: 20px;
  text-decoration: none;
  font-size: 0.9rem;
  transition: background .25s ease;
}

    .edit-btn:hover {
        background-color: var(--accent-hover);
        transform: translateY(-1px);
    }

.vote-btn {
    background: none;
    border: none;
    color: var(--text);
    font-size: 1.4rem;
    cursor: pointer;
    padding: 4px;
    transition: transform 0.2s ease, color .2s ease;
}

    .vote-btn:hover {
        transform: scale(1.2);
        color: var(--accent-soft);
    }

.nav-actions {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin-top: 15px;
}

.admin-btn {
    display: inline-block;
    padding: 10px 18px;
    border: 2px solid var(--accent);
    color: var(--accent);
    font-size: 1rem;
    font-weight: 500;
    border-radius: 30px;
    text-decoration: none;
    background: transparent;
    transition: all 0.3s ease;
}

    .admin-btn:hover {
        background-color: var(--accent);
        color: #fff;
    }

.prompt-btn {
    display: inline-block;
    padding: 12px 20px;
    background: linear-gradient(135deg, var(--accent), var(--accent-soft));
    color: #fff;
    font-size: 1.1rem;
    font-weight: bold;
    border-radius: 30px;
    text-decoration: none;
    box-shadow: var(--shadow-1);
    transition: all 0.3s ease;
}

    .prompt-btn:hover {
        transform: scale(1.05);
    }

.page-head {
    text-align: center;
    margin: 10px 0 20px;
}

.page-title {
    font-size: 1.8rem;
    margin: 0 0 15px;
    color: var(--accent);
    font-weight: 700;
}

.page-subtitle {
    margin-top: 6px;
    color: var(--text-muted);
    font-size: 0.98rem;
}

.form-card {
    max-width: 980px;
    margin: 0 auto 30px;
    background: var(--surface) !important;
    color: var(--text) !important;
    padding: 18px 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-1);
}

    .form-card .form-control,
    .form-card .form-select {
        background: var(--surface-2);
        color: var(--text);
        border-radius: 10px;
        border: 1px solid var(--border);
    }

        .form-card .form-control::placeholder {
            color: var(--text-muted);
        }

        .form-card .form-control:focus,
        .form-card .form-select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 .2rem rgba(140,108,196, .15);
            outline: none;
        }

    .form-card .form-label {
        font-weight: 600;
        color: #d8cdf2;
    }

.form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 10px;
}

.btn-secondary-link {
    display: inline-block;
    padding: 10px 16px;
    border: 2px solid var(--accent);
    color: var(--accent);
    border-radius: 30px;
    text-decoration: none;
    background: transparent;
    transition: all .25s ease, transform .2s ease;
}

    .btn-secondary-link:hover {
        background: var(--accent);
        color: #fff;
        transform: translateY(-1px);
    }

.create-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    background: linear-gradient(135deg, var(--accent), var(--accent-soft));
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    border: none;
    border-radius: 30px;
    cursor: pointer;
    box-shadow: var(--shadow-1);
    transition: transform .25s ease, background .25s ease, box-shadow .25s ease;
}

    .create-btn:hover {
        background: linear-gradient(135deg, var(--accent-hover), var(--accent));
        transform: translateY(-1px);
        box-shadow: var(--shadow-2);
    }

.btn-secondary-link,
.create-btn {
    text-align: center;
    justify-content: center;
    width: 100%;
}

.create-btn-admin {
    display: inline-block;
    padding: 12px 22px;
    background: linear-gradient(135deg, #6a4caf, #9d7bd8);
    color: white;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 30px;
    text-decoration: none;
    box-shadow: 0 4px 10px rgba(0,0,0,0.12);
    transition: transform .25s ease, background .25s ease, box-shadow .25s ease;
}

.btn-delete {
    margin-top: 15px;
    display: inline-block;
    padding: 10px 18px;
    background-color: var(--danger);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 30px;
    cursor: pointer;
    box-shadow: var(--shadow-1);
    transition: background .25s ease, transform .25s ease;
}

    .btn-delete:hover {
        background-color: var(--danger-hover);
        transform: translateY(-1px);
    }

.delete-btn-plain {
    background: none;
    border: none;
    padding: 0;
    color: var(--text);
    cursor: pointer;
}

    .delete-btn-plain:focus {
        outline: none;
    }

.delete-icon {
    width: 20px;
    height: 20px;
    display: inline-block;
    filter: brightness(0.9);
}

dl {
    margin: 0;
    padding: 0;
}

dt {
    font-weight: 600;
    color: var(--accent-soft);
    margin-top: 10px;
}

dd {
    margin-left: 0;
    color: var(--text-muted);
    word-wrap: break-word;
}

.table {
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
}

    .table thead th {
        background-color: #2a213f;
        color: #efeaff;
        border-bottom: 2px solid var(--accent);
    }

    .table td,
    .table th {
        color: var(--text) !important;
    }

    .table tbody tr {
        border-top: 1px solid var(--border);
    }

        .table tbody tr:hover {
            background: #262626;
        }

.admin-title {
    text-align: center;
    font-size: 2rem;
    color: var(--accent);
    font-weight: 700;
    margin: 25px 0 20px;
    letter-spacing: 0.5px;
}



.copy-btn {
    padding: 8px 10px;
    font-size: 15px;
    font-weight: 500;
    background-color: var(--surface-2);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px; 
    box-shadow: var(--shadow-1);
    transition: background .25s ease, color .25s ease, border-color .25s ease, transform .1s ease;
}

    .copy-btn:hover {
        background-color: #444; 
        border-color: var(--accent-soft); 
        color: var(--accent-soft);
    }

    .copy-btn:active {
        transform: scale(0.96);
    }

.like-area .copy-btn {
    margin-left: 8px;
}

