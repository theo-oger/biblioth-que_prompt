@using PromptLibrary_Modele.TableRef
@model IEnumerable<SubCategorie>

@{
    ViewData["Title"] = "index";
}
<header>
    <div>
        <a asp-action="Create" id="new-btn">Créer</a>
    </div>
</header>

<main class="gallery" id="gallery" style="padding: 50px;">
    @foreach (var item in Model)
    {
        <div class="prompt-card">
            <h2>@item.Nom</h2>

            <div style="text-decoration: underline solid #b39ed2d6;margin-bottom: 8px;">
                <i>Description :</i>
            </div>
            <p>@item.Description</p>

            <a asp-action="Edit" asp-route-id="@item.Id" class="edit-btn">Voir</a>
        </div>
    }
</main>
