@model PromptLibrary_Modele.TableRef.Categorie
@{
    ViewData["Title"] = "Créer une catégorie";
}

<section class="page-head">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <p class="page-subtitle">Renseigne le nom et la description de la catégorie</p>
</section>

<form asp-action="CreateCategorie" method="post" class="form-card">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Nom" class="form-label"></label>
        <input asp-for="Nom" class="form-control" />
        <span asp-validation-for="Nom" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="6"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-actions">
        <a asp-action="Index" asp-controller="Administration" class="btn-secondary-link">Retour</a>
        <button type="submit" class="create-btn">Créer</button>
    </div>
</form>
@section additionnalhead {
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" asp-append-version="true" />
}