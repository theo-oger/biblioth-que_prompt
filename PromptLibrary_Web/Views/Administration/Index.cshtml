@using PromptLibrary_Web.Models

@model AdministrationViewModel

<section>
    <h2 class="admin-title">Catégories</h2>

    <div class="d-flex justify-content-between align-items-center mb-2">

        <a class="create-btn-admin" asp-controller="Administration" asp-action="CreateCategorie">
            Créer une catégorie
        </a>

    </div>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Description</th>
                <th style="width:220px;">Actions</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Categories)
            {
                <tr>
                    <td>@c.Id</td>
                    <td>@c.Nom</td>

                    <td>
                        @{
                            var desc = c.Description ?? string.Empty;
                        }
                        @(desc.Length <= 100 ? desc : desc.Substring(0, 100) + "…")
                    </td>

                    <td>
                        <a class="edit-btn" asp-controller="Administration" asp-action="DetailCategorie" asp-route-id="@c.Id">Détails</a>
                        <a class="edit-btn" asp-controller="Administration" asp-action="EditCategorie" asp-route-id="@c.Id">Éditer</a>
                        <form asp-controller="Administration"
                              asp-action="DeleteCategorie"
                              asp-route-id="@c.Id"
                              method="post"
                              style="display:inline"
                              onsubmit="return confirm('Confirmer la suppression de la catégorie ?');">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="delete-btn-plain">
                                <img src="~/img/corbeille.png" class="delete-icon" />
                            </button>

                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section>
    <h2 class="admin-title">Framework</h2>
    @if (Model.Frameworks?.Any() == true)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <a class="create-btn-admin"
               asp-controller="Administration" asp-action="CreateFramework">
                Créer un Framework
            </a>
        </div>

        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Contenu</th>
                    <th style="width:220px;">Actions</th>
                </tr>
            </thead>
            <tbody>

                @foreach (var f in Model.Frameworks)
                {
                    <tr>
                        <td>@f.Id</td>
                        <td>@f.Nom</td>
                        <td>
                            @{
                                var desc = f.Description ?? string.Empty;
                            }
                            @(desc.Length <= 50 ? desc : desc.Substring(0, 50) + "...")
                        </td>
                        <td>
                            @{
                                var test = f.Contenu ?? string.Empty;
                            }
                            @(test.Length <= 50 ? test : test.Substring(0, 50) + "...")
                        </td>
                        <td>
                            <a class="edit-btn" asp-controller="Administration" asp-action="DetailFramework" asp-route-id="@f.Id">
                                Détails
                            </a>
                            <a class="edit-btn" asp-controller="Administration" asp-action="EditFramework" asp-route-id="@f.Id">
                                Éditer
                            </a>

                            <form asp-controller="Administration"
                                  asp-action="DeleteFramework"
                                  asp-route-id="@f.Id"
                                  method="post"
                                  style="display:inline"
                                  onsubmit="return confirm('Confirmer la suppression du framework ?');">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="delete-btn-plain">
                                    <img src="~/img/corbeille.png" class="delete-icon" />
                                </button>

                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    else
    {
        <p>Aucun framework disponible.</p>
    }

</section>

<section>
    <h2 class="admin-title">Sous-Catégories</h2>
    @if (Model.SubCategories?.Any() == true)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <a class="create-btn-admin"
               asp-controller="Administration" asp-action="CreateSubCategorie">
                Créer une Sous Catégorie
            </a>
        </div>

        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th style="width:220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.SubCategories)
                {
                    <tr>
                        <td>@s.Id</td>
                        <td>@s.Nom</td>
                        <td>
                            @{
                                var desc = s.Description ?? string.Empty;
                            }
                            @(desc.Length <= 100 ? desc : desc.Substring(0, 100) + "…")
                        </td>
                        <td>
                            <a class="edit-btn" asp-controller="Administration" asp-action="DetailSubCategorie" asp-route-id="@s.Id">
                                Détails
                            </a>
                            <a class="edit-btn" asp-controller="Administration" asp-action="EditSubCategorie" asp-route-id="@s.Id">
                                Éditer
                            </a>
                            <form asp-controller="Administration"
                                  asp-action="DeleteSubCategorie"
                                  asp-route-id="@s.Id"
                                  method="post"
                                  style="display:inline"
                                  onsubmit="return confirm('Confirmer la suppression de la catégorie ?');">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="delete-btn-plain">
                                    <img src="~/img/corbeille.png" class="delete-icon" />
                                </button>

                            </form>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    else
    {
        <p>Aucune sous‑catégorie disponible.</p>
    }
</section>

@section additionnalhead {
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" asp-append-version="true" />
}



