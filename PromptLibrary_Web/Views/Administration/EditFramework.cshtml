@using PromptLibrary_Modele.TableRef
@model Framework

@{
    ViewData["Title"] = "Modifier le framework";
}

<section class="page-head">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <p class="page-subtitle">Mets à jour le nom, la description et le contenu de ce framework</p>
</section>

<form asp-controller="Administration" asp-action="EditFramework" method="post" class="form-card">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Nom" class="form-label"></label>
        <input asp-for="Nom" class="form-control" />
        <span asp-validation-for="Nom" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="6"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Contenu" class="form-label"></label>
        <textarea asp-for="Contenu" class="form-control" rows="6"></textarea>
        <span asp-validation-for="Contenu" class="text-danger"></span>
    </div>

    <div class="form-actions">
        <a asp-controller="Administration" asp-action="Index" class="btn-secondary-link">Annuler</a>
        <button type="submit" class="create-btn">Enregistrer</button>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@section additionnalhead {
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" asp-append-version="true" />
}

